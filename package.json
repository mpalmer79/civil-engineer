{
  "name": "civil-engineer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "description": "Civil Engineer AI: Stormwater review-support platform with DXF intake, plan review workflow, response packages, resubmittal tracking, revision comparison, evidence traceability, and reviewer command center.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check:content": "node scripts/check-content-integrity.mjs",
    "check:complexity": "node scripts/check-complexity.mjs",
    "generate:api": "node scripts/generate-api-types.mjs",
    "check:contracts": "node scripts/generate-api-types.mjs --check",
    "generate:guide": "node scripts/generate-guide-knowledge.mjs",
    "check:guide": "node scripts/check-guide-knowledge.mjs",
    "check": "npm run typecheck && npm run lint && npm run check:content && npm run test",
    "verify": "npm run check && npm run build",
    "verify:live": "node scripts/verify-live-site.mjs",
    "verify:pilot": "node scripts/verify-pilot-release.mjs"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    },
    "vitest": {
      "vite": "$vite"
    },
    "@axe-core/playwright": {
      "playwright-core": "1.61.1"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.5",
    "eslint-config-next": "15.5.20",
    "jsdom": "24.1.0",
    "openapi-typescript": "7.10.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
