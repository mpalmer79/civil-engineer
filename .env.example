# Configuration for the Civil Engineer AI frontend (Next.js).
# Copy this file to .env.local for local development. On Railway this is set as a
# frontend service variable (see docs/RAILWAY_DEPLOYMENT_GUIDE.md).

# Base URL of the FastAPI backend. The frontend reads this at build and run time
# to call the API. Locally it points at the dev backend. In a deployment set it
# to the deployed backend URL (for example the Railway backend URL).
# Use the backend origin only, with no trailing slash and no path. Do not
# include /api/v1: the frontend appends /api/v1/... itself.
#   Correct: https://your-backend-service.up.railway.app
#   Wrong:   https://your-backend-service.up.railway.app/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
