# Configuration for the Civil Engineer AI frontend (Next.js).
# Copy this file to .env.local for local development. On Railway this is set as a
# frontend service variable (see docs/RAILWAY_DEPLOYMENT_GUIDE.md).

# Base URL of the FastAPI backend. The frontend reads this at build and run time
# to call the API. Locally it points at the dev backend. In a deployment set it
# to the deployed backend URL (for example the Railway backend URL).
# It must be the public origin only, with no trailing slash and no /api or
# /api/v1 path. The frontend API modules append /api/v1/... themselves, so a base
# URL that already includes /api/v1 would double the prefix and break every call.
# Deployment example: NEXT_PUBLIC_API_BASE_URL=https://your-backend-service.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Backend authentication and access control (Production Foundations Sprint 5).
# These are BACKEND service variables, not frontend variables. Never put the
# auth secret or any password in the frontend or in NEXT_PUBLIC_* variables.
# Set these on the backend service only.
# ---------------------------------------------------------------------------

# Signs local access tokens. Override with a strong, unique secret in any
# deployment. The built-in default is an insecure development-only placeholder.
# AUTH_SECRET_KEY=replace-with-a-long-random-secret

# Access token lifetime in minutes (default 120).
# AUTH_TOKEN_EXPIRE_MINUTES=120

# Keep the public Brookside Meadows demo and the demo reviewer fallback working
# without a login (default true).
# AUTH_DEMO_MODE=true

# Require a signed-in user for real (non-demo) project actions (default true).
# AUTH_REQUIRE_LOGIN_FOR_REAL_PROJECTS=true

# Allow reading demo_public projects without a login (default true).
# AUTH_ALLOW_PUBLIC_DEMO=true

# Seeded local demo credentials are for local development and the portfolio demo
# only. They MUST be changed or disabled before any real use. Set
# AUTH_SEED_DEMO_USERS=false to disable seeding demo users.
# AUTH_SEED_DEMO_USERS=true
# AUTH_DEMO_REVIEWER_PASSWORD=demo-reviewer-pass
# AUTH_DEMO_ADMIN_PASSWORD=demo-admin-pass

# ---------------------------------------------------------------------------
# Backend durable file storage (Production Foundations Sprint 6). These are
# BACKEND service variables, not frontend variables. Object storage credentials
# are backend-only and are read only when STORAGE_PROVIDER=s3. Never put storage
# credentials in the frontend or in any NEXT_PUBLIC_* variable.
# ---------------------------------------------------------------------------

# Storage backend: "local" stores uploads on the service file system for
# development; "s3" uses S3-compatible object storage for durable deployment
# storage. Default is local.
# STORAGE_PROVIDER=local

# Local storage directory (used when STORAGE_PROVIDER=local). Defaults to the
# project upload directory.
# LOCAL_STORAGE_DIR=./project_uploads

# S3-compatible object storage (used only when STORAGE_PROVIDER=s3).
# OBJECT_STORAGE_BUCKET=
# OBJECT_STORAGE_ENDPOINT_URL=        # leave empty for AWS S3; set for S3-compatible providers
# OBJECT_STORAGE_REGION=us-east-1
# OBJECT_STORAGE_ACCESS_KEY_ID=
# OBJECT_STORAGE_SECRET_ACCESS_KEY=
# OBJECT_STORAGE_FORCE_PATH_STYLE=true
# OBJECT_STORAGE_PUBLIC_BASE_URL=
# OBJECT_STORAGE_SIGNED_URL_EXPIRE_SECONDS=300

# ---------------------------------------------------------------------------
# Deployment diagnostics and observability (Production Foundations Sprint 10).
# No new variables are required. The backend validates the existing settings
# above and exposes safe operational diagnostics that never return secret
# values:
#   GET /health                          liveness (public)
#   GET /api/v1/readiness                database, config, storage readiness (public, sanitized)
#   GET /api/v1/diagnostics/environment  environment validation summary (organization admin only)
#   GET /api/v1/diagnostics/storage      storage provider status (authenticated user)
#   GET /api/v1/diagnostics/frontend-config   frontend integration hints (public)
# The frontend Deployment Status page is at /deployment-status. Verify a live
# deployment with: npm run verify:live -- --frontend <url> --backend <origin>.
# Never place AUTH_SECRET_KEY, OBJECT_STORAGE_* credentials, or any backend
# secret in a NEXT_PUBLIC_ variable. NEXT_PUBLIC_API_BASE_URL is the backend
# origin only, with no /api/v1 path.
