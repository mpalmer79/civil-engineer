# Local development configuration for the Civil Engineer AI backend.
# Copy this file to .env and adjust values as needed.

# SQLite is used for local Phase 2 storage. The path is relative to the
# backend working directory. Swap this for a PostgreSQL or Supabase URL later.
DATABASE_URL=sqlite:///./civil_engineer_ai.db

# Comma separated list of origins allowed to call the API from a browser.
# These cover the local Next.js dev server only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Review Assistant configuration.
# The default provider is the deterministic mock provider, so the project runs
# and tests pass without any paid API key. Live calls are disabled by default.
# Only the OpenAI live provider is implemented today. To use it, set
# AI_PROVIDER=openai, enable live calls, and provide an OpenAI key.
AI_PROVIDER=mock
AI_MODEL=mock-review-v1
AI_ENABLE_LIVE_CALLS=false
OPENAI_API_KEY=
PROMPT_VERSION=checklist_review_v1
