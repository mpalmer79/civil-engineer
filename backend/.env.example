# Configuration for the Civil Engineer AI backend.
# Copy this file to .env for local development and adjust values as needed.
# The same variables are set as Railway service variables for a deployment
# (see docs/RAILWAY_DEPLOYMENT_GUIDE.md).

# Deployment mode. development and pilot allow a local SQLite database so the
# prototype and tests run with no external service. production requires a Postgres
# DATABASE_URL and the app refuses to start on SQLite in that mode. See
# docs/PRODUCTION_DATABASE.md.
APP_ENV=development

# Database connection string. SQLite is the default for local development and
# tests; the path is relative to the backend working directory. For production
# SaaS, set this to a Postgres URL (for example a Railway Postgres plugin URL)
# and run database migrations with 'alembic upgrade head'. A legacy postgres://
# scheme is normalized automatically. On Railway a SQLite file lives on the
# service file system and is recreated from seed data on each deploy unless a
# persistent volume is mounted, so SQLite is not suitable for production data.
DATABASE_URL=sqlite:///./civil_engineer_ai.db
# Example production Postgres URL (do not commit a real secret):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Comma separated list of browser origins allowed to call the API. These cover
# the local Next.js dev server.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The single deployed frontend origin (for example the Railway frontend URL).
# When set, it is added to the allowed CORS origins, so a deployment only needs
# to set this one variable. Leave empty for local development.
FRONTEND_ORIGIN=

# Browser DXF upload storage and size limit. On Railway this is demo-local
# storage on the service file system and is not persistent across redeploys.
# Point CAD_UPLOAD_DIR at a mounted volume for persistence. MAX_CAD_UPLOAD_BYTES
# is accepted as an alias for the same limit.
CAD_UPLOAD_DIR=./cad_uploads
CAD_MAX_UPLOAD_BYTES=5000000

# Real project document upload (Production Foundations Sprint 1). Uploaded files
# are stored under PROJECT_UPLOAD_DIR using a safe generated file name, one
# subdirectory per project. On Railway this is demo-local storage and is not
# persistent across redeploys; point PROJECT_UPLOAD_DIR at a mounted volume for
# persistence. Only the listed extensions are accepted and the size limit is
# enforced during upload validation.
PROJECT_UPLOAD_DIR=./project_uploads
MAX_PROJECT_UPLOAD_BYTES=25000000
ALLOWED_PROJECT_UPLOAD_EXTENSIONS=.pdf,.dxf,.csv,.xlsx,.docx,.png,.jpg,.jpeg

# Demo mode loads the seeded Brookside Meadows demo data and keeps the
# deployment self-contained with no authentication and no external service.
# PUBLIC_DEMO_PROJECT_ID is the seeded reference project marked as the public
# demo at startup; the default matches the seeded Brookside Meadows fixture.
DEMO_MODE=true
PUBLIC_DEMO_PROJECT_ID=proj_brookside_meadows

# Production Phase 4B/4C account lifecycle and billing. Reset and invitation
# tokens are stored only as a one-way hash; these set their validity windows.
# AUTH_EXPOSE_DEV_TOKENS lets non-production environments return the plaintext
# reset/invite token so the flow can complete without an email provider. It is
# forced off in production. See docs/AUTH_LIFECYCLE.md.
AUTH_PASSWORD_RESET_EXPIRE_MINUTES=60
AUTH_INVITATION_EXPIRE_DAYS=14
AUTH_EXPOSE_DEV_TOKENS=true

# Email provider (Production Phase 4D). The default noop mailer logs a redacted
# delivery record and sends nothing. Set EMAIL_PROVIDER=smtp and the EMAIL_SMTP_*
# settings to deliver real reset and invitation emails. APP_PUBLIC_BASE_URL is the
# public frontend origin used to build links in emails. No SMTP credential is read
# while the provider is noop, and no credential is ever logged. See
# docs/EMAIL_DELIVERY.md.
EMAIL_PROVIDER=noop
EMAIL_FROM=no-reply@example.com
APP_PUBLIC_BASE_URL=http://localhost:3000
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true

# Billing and Stripe (Production Phase 4D). Minimal checkout for the professional
# plan and signature-verified webhooks are wired, but only become active when
# configured. Billing is active only when STRIPE_SECRET_KEY is set, checkout when
# all checkout settings are set, and webhooks when STRIPE_WEBHOOK_SECRET is set.
# These are backend-only and are never exposed to the frontend. No real payment is
# processed while STRIPE_SECRET_KEY is unset. Use test keys (sk_test_...) unless
# you intend live payments. See docs/STRIPE_BILLING.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_TEST_MODE=true

# Usage enforcement (Production Phase 4D). Advisory by default. Set true to
# hard-enforce the selected low-risk usage limits (project creation, document
# registration, review packet generation) for real organizations. The public demo
# is never enforced. See docs/BILLING_AND_USAGE.md.
USAGE_ENFORCEMENT_ENABLED=false

# AI Review Assistant configuration. The default provider is the deterministic
# mock provider, so the project runs and tests pass without any paid API key.
# Live calls are disabled by default. Only the OpenAI live provider is
# implemented today. To use it, set AI_PROVIDER=openai, enable live calls, and
# provide an OpenAI key.
AI_PROVIDER=mock
AI_MODEL=mock-review-v1
AI_ENABLE_LIVE_CALLS=false
OPENAI_API_KEY=
PROMPT_VERSION=checklist_review_v1
