# Configuration for the Civil Engineer AI backend.
# Copy this file to .env for local development and adjust values as needed.
# The same variables are set as Railway service variables for a deployment
# (see docs/RAILWAY_DEPLOYMENT_GUIDE.md).

# SQLite is used for local storage. The path is relative to the backend working
# directory. On Railway this lives on the service file system and is recreated
# from seed data on each deploy unless a persistent volume is mounted.
DATABASE_URL=sqlite:///./civil_engineer_ai.db

# Comma separated list of browser origins allowed to call the API. These cover
# the local Next.js dev server.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The single deployed frontend origin (for example the Railway frontend URL).
# When set, it is added to the allowed CORS origins, so a deployment only needs
# to set this one variable. Leave empty for local development.
FRONTEND_ORIGIN=

# Browser DXF upload storage and size limit. On Railway this is demo-local
# storage on the service file system and is not persistent across redeploys.
# Point CAD_UPLOAD_DIR at a mounted volume for persistence. MAX_CAD_UPLOAD_BYTES
# is accepted as an alias for the same limit.
CAD_UPLOAD_DIR=./cad_uploads
CAD_MAX_UPLOAD_BYTES=5000000

# Demo mode loads the seeded Brookside Meadows demo data and keeps the
# deployment self-contained with no authentication and no external service.
DEMO_MODE=true

# AI Review Assistant configuration. The default provider is the deterministic
# mock provider, so the project runs and tests pass without any paid API key.
# Live calls are disabled by default. Only the OpenAI live provider is
# implemented today. To use it, set AI_PROVIDER=openai, enable live calls, and
# provide an OpenAI key.
AI_PROVIDER=mock
AI_MODEL=mock-review-v1
AI_ENABLE_LIVE_CALLS=false
OPENAI_API_KEY=
PROMPT_VERSION=checklist_review_v1
