# Local development configuration for the Civil Engineer AI backend.
# Copy this file to .env and adjust values as needed.

# SQLite is used for local Phase 2 storage. The path is relative to the
# backend working directory. Swap this for a PostgreSQL or Supabase URL later.
DATABASE_URL=sqlite:///./civil_engineer_ai.db

# Comma separated list of origins allowed to call the API from a browser.
# These cover the local Next.js dev server only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
